---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import MobileCta from '../../../components/MobileCta.astro';
import PageScripts from '../../../components/PageScripts.astro';
import PriceTable from '../../../components/PriceTable.astro';
import CtaBand from '../../../components/CtaBand.astro';
import { SITE } from '../../../data/site.js';
import { LOCAL_PAGES, SERVICE_BY_SLUG, SUBURB_CHIPS, LOCAL_REVIEWS } from '../../../data/repairs.js';
import { HOURS } from '../../../data/content.js';
import { canonical, faqPageSchema, businessRef, localBusinessSchema } from '../../../lib/seo.js';

export function getStaticPaths() {
  return LOCAL_PAGES.map((page) => ({
    params: { service: page.service, suburb: page.suburb },
    props: { page },
  }));
}

const { page } = Astro.props;
const svc = SERVICE_BY_SLUG[page.service];
const path = `/repairs/${page.service}/${page.suburb}/`;

// Real weekday hours as the no-JS/server fallback (PageScripts refines per visitor).
const todayHours = HOURS.find((h) => h.dow === 1)?.hrs || '9:00 AM – 6:00 PM';

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Visit', href: '#visit' },
  { label: 'Blog', href: '/blog/' },
  { label: 'FAQ', href: '#faq' },
];

// Match the CURRENT service when resolving a nearby-suburb chip; only built
// same-service pages get a link, the rest render as plain (non-link) chips.
const builtSuburbHref = (name) => {
  const built = LOCAL_PAGES.find((l) => l.suburbName === name && l.service === page.service);
  return built ? `/repairs/${built.service}/${built.suburb}/` : null;
};
const nearby = SUBURB_CHIPS.filter((n) => n !== page.suburbName);

const schema = [
  localBusinessSchema(SITE, HOURS),
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `${svc.schemaName} in ${page.suburbName}`,
    areaServed: { '@type': 'City', name: page.suburbName, address: { '@type': 'PostalAddress', addressRegion: 'NSW', addressCountry: 'AU' } },
    provider: businessRef(SITE),
    offers: { '@type': 'Offer', price: svc.schemaPrice, priceCurrency: 'AUD' },
  },
  faqPageSchema(page.faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: canonical('/') },
      { '@type': 'ListItem', position: 2, name: 'Repairs', item: canonical('/repairs/') },
      { '@type': 'ListItem', position: 3, name: svc.label, item: canonical(`/repairs/${svc.slug}/`) },
      { '@type': 'ListItem', position: 4, name: page.suburbName, item: canonical(path) },
    ],
  },
];

const arrowSm = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>';
const phoneSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>';
const mapsHref = `https://maps.google.com/?q=${encodeURIComponent(SITE.mapsQuery)}`;
---
<Layout
  title={page.title}
  description={page.description}
  path={path}
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="#cta" />

  <main id="main-content">
  <section class="hero" style="padding-bottom: 72px;">
    <div class="hero-bg"></div>
    <div class="container-wide" style="position: relative; z-index: 1;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <a href="/repairs/">Repairs</a>
        <span class="crumb-sep">/</span>
        <a href={`/repairs/${svc.slug}/`}>{svc.label}</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">{page.suburbName}</span>
      </nav>
      <div class="hero-grid">
        <div>
          <span class="hero-badge">
            <span class="hero-badge-pill">{page.badgePill}</span>
            <span>{page.badgeNote}</span>
          </span>
          <h1 class="hero-title" style="font-size: clamp(38px, 5.2vw, 62px);" set:html={page.h1Html}></h1>
          <p class="hero-sub">{page.sub}</p>
          <div class="hero-ctas">
            <a href="#cta" class="btn btn-primary btn-lg">Get a free quote <Fragment set:html={arrowSm} /></a>
            <a href={SITE.phoneHref} class="btn btn-ghost btn-lg"><Fragment set:html={phoneSvg} /> {SITE.phone}</a>
          </div>
          <div class="trust-row">
            <div class="trust-text">
              <div class="stars">★★★★★ <strong style="margin-left: 6px;">4.9/5</strong></div>
              <div set:html={page.trust}></div>
            </div>
          </div>
          <div class="hero-infobar">
            <div><div class="hero-info-label">Today</div><div class="hero-info-value" id="today-hours">{todayHours}</div></div>
            <div><div class="hero-info-label">{page.turnaroundLabel}</div><div class="hero-info-value">{svc.turnaround}</div></div>
            <div><div class="hero-info-label">Warranty</div><div class="hero-info-value">6–12 months</div></div>
            <div><div class="hero-info-label">Status</div><div class="hero-info-value" id="open-status">…</div></div>
          </div>
        </div>
        <div>
          <div class="lhero-media">
            <img src={svc.img} alt={`${svc.alt} at Express Repairs ${page.suburbName}`} fetchpriority="high" decoding="async" />
            <div class="lhero-media-overlay"></div>
            <div class="lhero-price-tag">
              <div class="from">{svc.fromCaption}</div>
              <div class="amount">{svc.fromAmount}</div>
            </div>
            <div class="lhero-media-caption">
              <span>Shop 7C, Riverwood Plaza</span>
              <span class="cap-sub">{page.captionSub}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="pricing" style="background: var(--bg-soft); padding-top: 80px;">
    <div class="container-wide">
      <span class="eyebrow">{svc.priceEyebrow}</span>
      <h2 class="section-title" style="margin-top: 14px;">Up-front prices, by brand.</h2>
      <p class="section-lede">Final quote depends on your exact model — call or drop in and we'll confirm before touching your phone. No fix, no fee.</p>
      <PriceTable colLabel={svc.priceColLabel} note={svc.priceNote} rows={svc.rows} />
    </div>
  </section>

  <section class="section-tight" id="why">
    <div class="container-wide">
      <span class="eyebrow">Why locals choose us</span>
      <h2 class="section-title" style="margin-top: 14px; font-size: clamp(28px, 3.5vw, 40px);">The same promise on every repair.</h2>
      <div class="warr-grid">
        {svc.warranties.map((w) => (
          <div class="warr-card"><div class="warr-check">✓</div><div class="warr-title">{w.title}</div><div class="warr-desc">{w.desc}</div></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="visit" style="background: var(--bg-soft);">
    <div class="container-wide">
      <span class="eyebrow">{page.visitEyebrow}</span>
      <h2 class="section-title" style="margin-top: 14px;">{page.visitTitle}</h2>
      <p class="section-lede">{page.visitLede}</p>
      <div class="area-grid">
        <div>
          <div class="area-copy">
            {page.areaCopy.map((p) => <p set:html={p}></p>)}
          </div>
          <div class="area-facts">
            {page.areaFacts.map((f) => (
              <div class="area-fact"><div class="area-fact-label">{f.label}</div><div class="area-fact-value">{f.value}</div></div>
            ))}
          </div>
        </div>
        <div class="map-card">
          <div class="map-card-bg"></div>
          <div class="map-card-pin">
            <div class="map-pin-card">
              <div class="map-pin-dot">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div style="font-weight: 800; font-size: 18px; line-height: 1.25;">{SITE.storeName} <span style="display:block; font-weight:600; font-size:13px; color:var(--text-muted); margin-top:3px;">{SITE.storeSub}</span></div>
              <div style="font-size: 13px; color: var(--text-muted); margin-top: 2px;">{SITE.addressShort}</div>
              <a href={mapsHref} target="_blank" rel="noreferrer" class="btn btn-primary btn-sm" style="margin-top: 14px;">Open in Maps</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="reviews">
    <div class="container-wide">
      <span class="eyebrow">Reviews</span>
      <h2 class="section-title" style="margin-top: 14px;">{page.reviewsTitle}</h2>
      <p class="section-lede" style="margin-bottom: 44px;">{page.reviewsLede}</p>
      <div class="t-grid">
        {LOCAL_REVIEWS.map((r) => (
          <div class="t-card">
            <div class="t-stars">★★★★★</div>
            <p class="t-quote">"{r.text}"</p>
            <div class="t-author">
              <span class="avatar-initials">{r.initials}</span>
              <div>
                <div class="t-author-name">{r.name}</div>
                <div class="t-author-source">{r.source}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight" id="faq" style="background: var(--bg-soft); padding-bottom: 96px;">
    <div class="container-wide">
      <div style="text-align: center;">
        <span class="eyebrow">FAQ</span>
        <h2 class="section-title" style="margin-top: 14px; margin-inline: auto;">{page.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {page.faqs.map((f, i) => (
          <div class="faq-item" data-open={i === 0 ? 'true' : 'false'}>
            <button type="button" class="faq-q" aria-expanded={i === 0 ? 'true' : 'false'} aria-controls={`faq-a-${i}`}><span>{f.q}</span><span class="faq-toggle" aria-hidden="true">+</span></button>
            <div class="faq-a" id={`faq-a-${i}`}>{f.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-wide">
      <div class="link-chip-group" style="margin-top: 0;">
        <div class="link-chip-label">{svc.label} near {page.suburbName}</div>
        <div class="link-chips">
          {nearby.slice(0, 9).map((name) => (
            builtSuburbHref(name)
              ? <a class="link-chip" href={builtSuburbHref(name)}>{name} <span class="chip-arrow">→</span></a>
              : <span class="link-chip link-chip--static">{name}</span>
          ))}
        </div>
      </div>
      <div class="link-chip-group">
        <div class="link-chip-label">Other repairs in {page.suburbName}</div>
        <div class="link-chips">
          <a class="link-chip" href="/repairs/battery/">Battery replacement <span class="chip-arrow">→</span></a>
          <a class="link-chip" href="/repairs/charging-port/">Charging port <span class="chip-arrow">→</span></a>
          <a class="link-chip" href="/repairs/back-glass/">Back glass <span class="chip-arrow">→</span></a>
          <a class="link-chip" href="/repairs/camera/">Camera repair <span class="chip-arrow">→</span></a>
          <a class="link-chip" href="/repairs/water-damage/">Water damage <span class="chip-arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title={page.ctaTitle} secondaryLabel="Get a free quote" secondaryHref="#cta" />
  </main>

  <SiteFooter />
  <MobileCta />
  <PageScripts />
</Layout>
