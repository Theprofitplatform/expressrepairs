---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import MobileCta from '../../components/MobileCta.astro';
import PageScripts from '../../components/PageScripts.astro';
import PriceTable from '../../components/PriceTable.astro';
import CtaBand from '../../components/CtaBand.astro';
import { SITE } from '../../data/site.js';
import { SERVICES, SUBURB_CHIPS, LOCAL_PAGES } from '../../data/repairs.js';
import { HOURS } from '../../data/content.js';
import { canonical, faqPageSchema, businessRef } from '../../lib/seo.js';

export function getStaticPaths() {
  return SERVICES.map((svc) => ({ params: { service: svc.slug }, props: { svc } }));
}

const { svc } = Astro.props;
const path = `/repairs/${svc.slug}/`;

// Real weekday hours as the no-JS/server fallback (PageScripts refines this to
// the visitor's actual "today" client-side). Never a made-up time.
const todayHours = HOURS.find((h) => h.dow === 1)?.hrs || '9:00 AM – 6:00 PM';

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'How it works', href: '#process' },
  { label: 'Blog', href: '/blog/' },
  { label: 'FAQ', href: '#faq' },
];

// Suburbs built for THIS service get a real href; the rest render as plain
// (non-link) chips so we never ship crawlable dead "#" links.
const localFor = new Map(LOCAL_PAGES.filter((l) => l.service === svc.slug).map((l) => [l.suburbName, `/repairs/${l.service}/${l.suburb}/`]));

const otherServices = SERVICES.filter((s) => s.slug !== svc.slug);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: svc.schemaName,
    provider: businessRef(SITE),
    offers: { '@type': 'Offer', price: svc.schemaPrice, priceCurrency: 'AUD' },
  },
  faqPageSchema(svc.faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: canonical('/') },
      { '@type': 'ListItem', position: 2, name: 'Repairs', item: canonical('/repairs/') },
      { '@type': 'ListItem', position: 3, name: svc.label, item: canonical(path) },
    ],
  },
];

const arrowSm = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>';
const phoneSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>';
---
<Layout
  title={svc.title}
  description={svc.description}
  path={path}
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="#cta" />

  <main id="main-content">
  <section class="hero" style="padding-bottom: 72px;">
    <div class="hero-bg"></div>
    <div class="container-wide" style="position: relative; z-index: 1;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/repairs/">Repairs</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">{svc.label}</span>
      </nav>
      <div class="hero-grid">
        <div>
          <span class="hero-badge">
            <span class="hero-badge-pill">{svc.badgePill}</span>
            <span>{svc.badgeNote}</span>
          </span>
          <h1 class="hero-title" style="font-size: clamp(38px, 5.2vw, 62px);" set:html={svc.h1Html}></h1>
          <p class="hero-sub">{svc.sub}</p>
          <div class="hero-ctas">
            <a href="#pricing" class="btn btn-primary btn-lg">See pricing <Fragment set:html={arrowSm} /></a>
            <a href={SITE.phoneHref} class="btn btn-ghost btn-lg"><Fragment set:html={phoneSvg} /> {SITE.phone}</a>
          </div>
          <div class="hero-infobar">
            <div><div class="hero-info-label">Today</div><div class="hero-info-value" id="today-hours">{todayHours}</div></div>
            <div><div class="hero-info-label">Turnaround</div><div class="hero-info-value">{svc.turnaround}</div></div>
            <div><div class="hero-info-label">Warranty</div><div class="hero-info-value">6–12 months</div></div>
            <div><div class="hero-info-label">Status</div><div class="hero-info-value" id="open-status">…</div></div>
          </div>
        </div>
        <div>
          <div class="lhero-media">
            <img src={svc.img} alt={svc.alt} fetchpriority="high" decoding="async" />
            <div class="lhero-media-overlay"></div>
            <div class="lhero-price-tag">
              <div class="from">{svc.fromCaption}</div>
              <div class="amount">{svc.fromAmount}</div>
            </div>
            <div class="lhero-media-caption">
              <span>Fitted, tested &amp; warrantied</span>
              <span class="cap-sub">All major brands</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="pricing" style="background: var(--bg-soft); padding-top: 80px;">
    <div class="container-wide">
      <span class="eyebrow">{svc.priceEyebrow}</span>
      <h2 class="section-title" style="margin-top: 14px;">Up-front prices, by brand.</h2>
      <p class="section-lede">Final quote depends on your exact model — call or drop in and we'll confirm before touching your phone. No fix, no fee.</p>
      <PriceTable colLabel={svc.priceColLabel} note={svc.priceNote} rows={svc.rows} />
    </div>
  </section>

  <section class="section-tight" id="process">
    <div class="container-wide">
      <span class="eyebrow">How it works</span>
      <h2 class="section-title" style="margin-top: 14px; font-size: clamp(28px, 3.5vw, 40px);">Three steps, one short visit.</h2>
      <div class="process-strip" style="margin-top: 36px;">
        <div class="process-step"><div class="process-step-num">1</div><div class="process-step-title">Pick your device</div><div class="process-step-desc">Brand &amp; model, on our site or in store</div></div>
        <div class="process-step"><div class="process-step-num">2</div><div class="process-step-title">Confirm the price</div><div class="process-step-desc">Quoted up front, before any work starts</div></div>
        <div class="process-step"><div class="process-step-num">3</div><div class="process-step-title">Walk out fixed</div><div class="process-step-desc">Tested &amp; warrantied, usually within the hour</div></div>
      </div>
    </div>
  </section>

  <section class="section-tight" style="background: var(--bg-soft);">
    <div class="container-wide">
      <span class="eyebrow">Our promise</span>
      <h2 class="section-title" style="margin-top: 14px; font-size: clamp(28px, 3.5vw, 40px);">Every repair, the same promise.</h2>
      <div class="warr-grid">
        {svc.warranties.map((w) => (
          <div class="warr-card"><div class="warr-check">✓</div><div class="warr-title">{w.title}</div><div class="warr-desc">{w.desc}</div></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight" id="faq">
    <div class="container-wide">
      <div style="text-align: center;">
        <span class="eyebrow">FAQ</span>
        <h2 class="section-title" style="margin-top: 14px; margin-inline: auto;">{svc.label} questions, answered.</h2>
      </div>
      <div class="faq-list">
        {svc.faqs.map((f, i) => (
          <div class="faq-item" data-open={i === 0 ? 'true' : 'false'}>
            <button type="button" class="faq-q" aria-expanded={i === 0 ? 'true' : 'false'} aria-controls={`faq-a-${i}`}><span>{f.q}</span><span class="faq-toggle" aria-hidden="true">+</span></button>
            <div class="faq-a" id={`faq-a-${i}`}>{f.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight" style="background: var(--bg-soft);">
    <div class="container-wide">
      <div class="link-chip-group" style="margin-top: 0;">
        <div class="link-chip-label">{svc.label} near you</div>
        <div class="link-chips">
          {SUBURB_CHIPS.slice(0, 9).map((name) => (
            localFor.has(name)
              ? <a class="link-chip" href={localFor.get(name)}>{name} <span class="chip-arrow">→</span></a>
              : <span class="link-chip link-chip--static">{name}</span>
          ))}
        </div>
      </div>
      <div class="link-chip-group">
        <div class="link-chip-label">Other repairs</div>
        <div class="link-chips">
          {otherServices.map((s) => (
            <a class="link-chip" href={`/repairs/${s.slug}/`}>{s.label} <span class="chip-arrow">→</span></a>
          ))}
          <a class="link-chip" href="/repairs/">All repairs <span class="chip-arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    title={svc.ctaTitle}
    secondaryLabel="Visit the Riverwood store"
    secondaryHref="/repairs/screen/riverwood/"
  />
  </main>

  <SiteFooter />
  <MobileCta />
  <PageScripts />
</Layout>
