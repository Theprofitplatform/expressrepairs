---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileCta from '../components/MobileCta.astro';
import PageScripts from '../components/PageScripts.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE } from '../data/site.js';
import { SUBURB_CHIPS, LOCAL_PAGES } from '../data/repairs.js';
import { breadcrumbSchema } from '../lib/seo.js';

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Screen Repair', href: '/repairs/screen/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Visit', href: '#visit' },
  { label: 'FAQ', href: '/#faq' },
];

const builtLocal = new Map(LOCAL_PAGES.map((l) => [l.suburbName, `/repairs/${l.service}/${l.suburb}/`]));

const schema = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Repairs', path: '/repairs/' },
]);

const arrow = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>';
---
<Layout
  title="Phone Repairs Riverwood — Screens, Batteries & More | Express Repairs"
  description="Same-day phone repairs at Riverwood Plaza. Screens from $99, batteries from $59, free diagnostics. Walk-ins welcome Mon–Sat, 6–12 month warranty."
  path="/repairs/"
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="#cta" />

  <main id="main-content">
  <section class="hero" style="padding-bottom: 24px;">
    <div class="hero-bg"></div>
    <div class="container-wide" style="position: relative; z-index: 1;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">Repairs</span>
      </nav>
      <span class="hero-badge">
        <span class="hero-badge-pill">Express</span>
        <span>Riverwood Plaza · Same-day repairs · Open Mon–Sat</span>
      </span>
      <h1 class="hero-title" style="font-size: clamp(38px, 5.2vw, 62px); max-width: 760px;">
        Every repair, <em>priced up front</em>.
      </h1>
      <p class="hero-sub">
        Pick what's broken and we'll show you the price before you walk in. Most repairs are done the same day at our Riverwood Plaza store — many while you wait.
      </p>
      <div class="hero-ctas">
        <a href="#services" class="btn btn-primary btn-lg">Browse repairs <Fragment set:html={arrow} /></a>
        <a href={SITE.phoneHref} class="btn btn-ghost btn-lg">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {SITE.phone}
        </a>
      </div>
    </div>
  </section>

  <section class="section" id="services" style="padding-top: 56px;">
    <div class="container-wide">
      <div class="bento-grid" style="margin-top: 0;">
        <a href="/repairs/screen/" class="bento-card bento-hero">
          <div class="bento-img" style="background-image: url('/images/screen-repair.jpg');"></div>
          <div class="bento-overlay"></div>
          <span class="bento-badge pop">Most Popular</span>
          <div class="bento-body">
            <h3 class="bento-title">Screen Repair</h3>
            <p class="bento-desc">Cracked or shattered? Back to mint in under an hour.</p>
            <div class="bento-meta"><span class="bento-price">from $99</span><span class="bento-arrow">View pricing <Fragment set:html={arrow} /></span></div>
          </div>
        </a>
        <a href="/repairs/battery/" class="bento-card bento-tall">
          <div class="bento-img" style="background-image: url('/images/battery-repair.jpg');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-body">
            <h3 class="bento-title">Battery Replacement</h3>
            <p class="bento-desc">Fresh cells so you stop chasing power outlets.</p>
            <div class="bento-meta"><span class="bento-price">from $59</span><span class="bento-arrow">View <Fragment set:html={arrow} /></span></div>
          </div>
        </a>
        <a href="/repairs/back-glass/" class="bento-card bento-small">
          <div class="bento-img" style="background-image: url('/images/glass-repair.jpg');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-body">
            <h3 class="bento-title">Back Glass</h3>
            <div class="bento-meta"><span class="bento-price">from $69</span><span class="bento-arrow">Select <Fragment set:html={arrow} /></span></div>
          </div>
        </a>
        <a href="/repairs/charging-port/" class="bento-card bento-small">
          <div class="bento-img" style="background-image: url('/images/port-repair.jpg');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-body">
            <h3 class="bento-title">Charging Port</h3>
            <div class="bento-meta"><span class="bento-price">from $49</span><span class="bento-arrow">Select <Fragment set:html={arrow} /></span></div>
          </div>
        </a>
        <a href="/repairs/water-damage/" class="bento-card bento-wide">
          <div class="bento-img" style="background-image: url('/images/other-repairs.jpg');"></div>
          <div class="bento-overlay"></div>
          <div class="bento-body">
            <h3 class="bento-title">Other Repairs</h3>
            <p class="bento-desc">Water damage, speakers, cameras — we've seen it all.</p>
            <div class="bento-meta"><span class="bento-price">custom quote</span><span class="bento-arrow">Ask us <Fragment set:html={arrow} /></span></div>
          </div>
        </a>
        <a href="#cta" class="bento-card bento-small">
          <div class="bento-img" style="background-image: url('/images/diagnostic.jpg');"></div>
          <div class="bento-overlay"></div>
          <span class="bento-badge free">Free</span>
          <div class="bento-body">
            <h3 class="bento-title">Free Diagnostic</h3>
            <div class="bento-meta"><span class="bento-price">free</span><span class="bento-arrow">Book <Fragment set:html={arrow} /></span></div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section-tight" style="background: var(--bg-soft);">
    <div class="container-wide">
      <span class="eyebrow">How it works</span>
      <h2 class="section-title" style="margin-top: 14px; font-size: clamp(28px, 3.5vw, 40px);">Three steps, one short visit.</h2>
      <div class="process-strip" style="margin-top: 36px; background: var(--surface);">
        <div class="process-step"><div class="process-step-num">1</div><div class="process-step-title">Pick your device</div><div class="process-step-desc">Brand &amp; model, on our site or in store</div></div>
        <div class="process-step"><div class="process-step-num">2</div><div class="process-step-title">Choose the repair</div><div class="process-step-desc">Price confirmed up front</div></div>
        <div class="process-step"><div class="process-step-num">3</div><div class="process-step-title">Walk out fixed</div><div class="process-step-desc">Tested &amp; warrantied, same day</div></div>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-wide">
      <span class="eyebrow">Our promise</span>
      <h2 class="section-title" style="margin-top: 14px; font-size: clamp(28px, 3.5vw, 40px);">We stand behind every repair.</h2>
      <div class="warr-grid">
        <div class="warr-card"><div class="warr-check">✓</div><div class="warr-title">6–12 Month Warranty</div><div class="warr-desc">All repairs covered by manufacturer-grade warranty.</div></div>
        <div class="warr-card"><div class="warr-check">✓</div><div class="warr-title">Original-Quality Parts</div><div class="warr-desc">Genuine OEM or premium aftermarket, always.</div></div>
        <div class="warr-card"><div class="warr-check">✓</div><div class="warr-title">Free Diagnostics</div><div class="warr-desc">No charge for phone assessment and quote.</div></div>
        <div class="warr-card"><div class="warr-check">✓</div><div class="warr-title">Same-Day Service</div><div class="warr-desc">Most repairs completed in 30–90 minutes.</div></div>
      </div>
    </div>
  </section>

  <section class="section-tight" id="visit" style="background: var(--bg-soft);">
    <div class="container-wide">
      <span class="eyebrow">Areas we serve</span>
      <h2 class="section-title" style="margin-top: 14px; font-size: clamp(28px, 3.5vw, 40px);">One store, the whole St George area.</h2>
      <p class="section-lede">We're at Riverwood Plaza, 257 Belmore Rd — a short trip from anywhere on the T8 line.</p>
      <div class="link-chip-group">
        <div class="link-chips">
          {SUBURB_CHIPS.map((name) => (
            builtLocal.has(name)
              ? <a class="link-chip" href={builtLocal.get(name)}>{name} <span class="chip-arrow">→</span></a>
              : <span class="link-chip link-chip--static">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    title="Not sure what's broken? Bring it in — diagnosis is free."
    sub="Call now or drop by Riverwood Plaza. We'll tell you what's wrong and what it costs, no obligation."
    secondaryLabel="See local pricing"
    secondaryHref="/repairs/screen/riverwood/"
  />
  </main>

  <SiteFooter />
  <MobileCta />
  <PageScripts />
</Layout>
