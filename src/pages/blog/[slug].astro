---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import MobileCta from '../../components/MobileCta.astro';
import CtaBand from '../../components/CtaBand.astro';
import { POSTS } from '../../data/posts.js';
import { SITE } from '../../data/site.js';
import { canonical, faqPageSchema, absoluteUrl } from '../../lib/seo.js';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  return POSTS.filter((p) => p.slug).map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const path = `/blog/${post.slug}/`;

// Optimised hero image: astro:assets can only transform images imported from
// src/, so post.img (a /images/ public path, used for OG + schema URLs) is
// matched by filename against the copies in src/assets/blog/. Falls back to the
// raw public path if an image hasn't been added there yet.
const heroModules = import.meta.glob('../../assets/blog/*.{jpg,jpeg,png,webp}', { eager: true, import: 'default' });
const heroImg = heroModules[`../../assets/blog/${post.img.split('/').pop()}`];

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Screen Repair', href: '/repairs/screen/' },
  { label: 'Blog', href: '/blog/' },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.excerpt,
    datePublished: post.dateISO,
    dateModified: post.dateModified || post.dateISO,
    image: `${canonical('/').replace(/\/$/, '')}${post.img}`,
    author: { '@type': 'Organization', name: SITE.name, url: canonical('/') },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      ...(SITE.logo && { logo: { '@type': 'ImageObject', url: absoluteUrl(SITE.logo), width: 512, height: 512 } }),
    },
    mainEntityOfPage: canonical(path),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: canonical('/') },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: canonical('/blog/') },
      { '@type': 'ListItem', position: 3, name: post.title, item: canonical(path) },
    ],
  },
];

if (post.faqs?.length) schema.push(faqPageSchema(post.faqs));
---
<Layout
  title={`${post.title} | Express Repairs`}
  description={post.excerpt}
  path={path}
  schema={schema}
  ogType="article"
  image={post.img}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="/repairs/screen/" />

  <article id="main-content">
    <div class="article-hero">
      <div class="container-wide">
        <div class="article-head">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="crumb-sep">/</span>
            <a href="/blog/">Blog</a>
            <span class="crumb-sep">/</span>
            <span class="crumb-current">{post.tag}</span>
          </nav>
          <div class="post-meta">
            <span class="post-tag">{post.tag}</span>
            <span>{post.date}</span>
            <span class="meta-dot">·</span>
            <span>{post.read}</span>
          </div>
          <h1 class="article-title">{post.title}</h1>
          <p class="article-lede">{post.lede}</p>
        </div>
        <div class="article-hero-img">
          {heroImg
            ? <Image src={heroImg} alt={post.imgAlt ?? post.title} widths={[600, 980, 1400]} sizes="(min-width: 1020px) 980px, 100vw" loading="eager" fetchpriority="high" />
            : <img src={post.img} alt={post.imgAlt ?? post.title} loading="eager" />}
        </div>
      </div>
    </div>

    <div class="container-wide">
      <div class="article-body" set:html={post.body}></div>
      <div class="article-foot">
        <span>Written by the Express Repairs team · Riverwood, Sydney</span>
        <a href="/blog/" style="color: var(--brand-700); font-weight: 700;">← All posts</a>
      </div>
    </div>
  </article>

  <CtaBand
    title="Cracked screen? Fixed by this afternoon."
    sub="Free diagnostic at Riverwood Plaza — price confirmed before we start."
    secondaryLabel="See pricing"
    secondaryHref="/repairs/screen/"
  />

  <SiteFooter />
  <MobileCta />
</Layout>
