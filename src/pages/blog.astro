---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileCta from '../components/MobileCta.astro';
import CtaBand from '../components/CtaBand.astro';
import { POSTS, BLOG_TAGS } from '../data/posts.js';
import { breadcrumbSchema } from '../lib/seo.js';

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Screen Repair', href: '/repairs/screen/' },
  { label: 'Blog', href: '/blog/' },
];

const featured = POSTS.find((p) => p.featured);
const rest = POSTS.filter((p) => p !== featured);
const postHref = (p) => (p.slug ? `/blog/${p.slug}/` : '#');

const schema = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
]);
---
<Layout
  title="Blog — Phone Repair Guides & Advice | Express Repairs"
  description="Honest guides from the repair bench: what repairs cost, when to fix vs replace, and how to keep your phone alive longer. From Express Repairs, Riverwood."
  path="/blog/"
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="/repairs/" />

  <section class="hero" style="padding-bottom: 0;">
    <div class="hero-bg"></div>
    <div class="container-wide" style="position: relative; z-index: 1;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">Blog</span>
      </nav>
      <span class="eyebrow">From the repair bench</span>
      <h1 class="hero-title" style="font-size: clamp(36px, 4.8vw, 58px); margin-top: 16px; max-width: 720px;">
        Guides &amp; advice, <em>no jargon</em>.
      </h1>
      <p class="hero-sub">
        What repairs really cost, when fixing beats replacing, and how to keep your phone alive longer — written by the people who fix them every day.
      </p>
      <div class="tag-row">
        {BLOG_TAGS.map((t, i) => <button class={`tag-pill ${i === 0 ? 'active' : ''}`}>{t}</button>)}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 40px;">
    <div class="container-wide">
      {featured && (
        <a href={postHref(featured)} class="post-featured">
          <div class="post-featured-img" style={`background-image: url('${featured.img}');`}></div>
          <div class="post-featured-body">
            <div class="post-meta">
              <span class="post-tag">{featured.tag}</span>
              <span>{featured.date}</span>
              <span class="meta-dot">·</span>
              <span>{featured.read}</span>
            </div>
            <h2 class="post-featured-title">{featured.title}</h2>
            <p class="post-featured-excerpt">{featured.excerpt}</p>
            <span style="color: var(--brand-700); font-weight: 700; font-size: 14.5px;">Read the guide →</span>
          </div>
        </a>
      )}

      <div class="post-grid">
        {rest.map((p) => (
          <a href={postHref(p)} class="post-card">
            <div class="post-card-img" style={`background-image: url('${p.img}');`}></div>
            <div class="post-card-body">
              <h3 class="post-card-title">{p.title}</h3>
              <p class="post-card-excerpt">{p.excerpt}</p>
              <div class="post-meta">
                <span class="post-tag">{p.tag}</span>
                <span>{p.date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    title="Reading about a problem you have right now?"
    sub="Skip the research — bring it in and we'll diagnose it free at Riverwood Plaza."
    secondaryLabel="Browse repairs"
    secondaryHref="/repairs/"
  />

  <SiteFooter />
  <MobileCta />
</Layout>
