---
import Layout from '../layouts/Layout.astro';
import { Nav, Hero, RepairServices, Plans, Accessories } from '../components/sections.jsx';
import { BrandsStrip, WhyUs, Testimonials, Warranty, FAQ, Store, Contact, Footer } from '../components/sections2.jsx';
import { localBusinessSchema, faqPageSchema } from '../lib/seo.js';
import { SITE } from '../data/site.js';
import { FAQS, HOURS } from '../data/content.js';

const schema = [localBusinessSchema(SITE, HOURS), faqPageSchema(FAQS)];
const description =
  'Same-day phone repairs in Sydney — screen, battery, charging port and more, backed by a 6–12 month warranty. Free 20-second quote.';
---
<Layout
  title="Express Repairs — Fast, trusted phone & device repairs"
  description={description}
  path="/"
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-herovariant': 'split', 'data-planstyle': 'cards', 'data-fontpair': 'mix', 'data-dark': 'false' }}
>
  {/* Static chrome + content render to plain HTML (no JS). Only the genuinely
      interactive sections hydrate as islands: Hero (booking widget) eagerly,
      the rest on view. */}
  <Nav />
  <main id="main-content">
    <Hero client:load />
    <RepairServices />
    <Plans client:visible />
    <Accessories />
    <BrandsStrip />
    <WhyUs />
    <Testimonials />
    <Warranty />
    <FAQ client:visible />
    <Store client:visible />
    <Contact client:visible />
  </main>
  <Footer />
  <a href={SITE.phoneHref} class="mobile-call-cta">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
    Call {SITE.phone}
  </a>
</Layout>
