---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import MobileCta from '../../components/MobileCta.astro';
import { breadcrumbSchema } from '../../lib/seo.js';

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Shop', href: '/shop/' },
];

const schema = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Shop', path: '/shop/' },
  { name: 'Search', path: '/shop/search/' },
]);
---
<Layout
  title="Search Accessories | Express Repairs Shop"
  description="Search our full range of phone cases, screen protectors, chargers, cables and audio — ship Australia-wide or free pickup at Riverwood Plaza."
  path="/shop/search/"
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="/shop/cart/" />

  <main id="main-content" class="section">
    <div class="container-wide">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <a href="/shop/">Shop</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">Search</span>
      </nav>

      <h1 class="section-title" style="margin-top: 16px; font-size: clamp(28px, 3.2vw, 38px);">Search the shop</h1>

      <form action="/shop/search/" style="margin-top: 20px; max-width: 520px; display: flex; gap: 8px;">
        <input
          type="search"
          id="q"
          name="q"
          placeholder="e.g. iPhone 15 case"
          autocomplete="off"
          style="flex: 1; padding: 12px 16px; font-size: 16px; border: 1px solid var(--border, #d0d5dd); border-radius: 10px;"
        />
        <button type="submit" class="btn btn-primary btn-sm">Search</button>
      </form>

      <p id="search-status" class="hero-sub" style="margin-top: 20px;">Type to search 3,000+ accessories.</p>

      <div id="search-results" class="acc-grid" style="margin-top: 16px;"></div>

      <p style="margin-top: 40px;"><a href="/shop/">← All categories</a></p>
    </div>
  </main>

  <SiteFooter />
  <MobileCta />
  <script>
    import { searchProducts } from '../../shop/search-core.js';

    const input = document.getElementById('q');
    const status = document.getElementById('search-status');
    const results = document.getElementById('search-results');
    const fmtPrice = (c) => (c % 100 === 0 ? `$${c / 100}` : `$${(c / 100).toFixed(2)}`);
    let index = null;

    const load = async () => {
      index ??= await fetch('/shop/search-index.json').then((r) => r.json());
      return index;
    };

    const esc = (s) => s.replace(/[&<>"']/g, (ch) => `&#${ch.charCodeAt(0)};`);

    const run = async () => {
      const q = input.value.trim();
      if (!q) { status.textContent = 'Type to search 3,000+ accessories.'; results.innerHTML = ''; return; }
      const { hits, total, partial } = searchProducts(await load(), q, 50);
      status.textContent = hits.length
        ? partial
          ? `No exact matches for “${q}” — showing ${total} closest result${total === 1 ? '' : 's'}`
          : `${total} result${total === 1 ? '' : 's'}${total > 50 ? ', showing first 50' : ''}`
        : `No results for “${q}” — try fewer words, or call us on 0415 303 300.`;
      // Every product image is mirrored to R2 keyed by id, so the thumb URL is
      // derived here instead of bloating the search index with 3,500 URLs.
      results.innerHTML = hits.slice(0, 50).map((p) => `
        <a href="/shop/${esc(p.id)}/" class="acc-card">
          <div class="acc-visual">
            <img
              src="https://img.expressrepairs.com.au/products/${esc(p.id)}.webp"
              alt="${esc(p.name)}"
              loading="lazy"
              decoding="async"
              width="400"
              height="300"
              style="width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: contain; background: #fff; padding: 12px; box-sizing: border-box;"
              onerror="this.closest('.acc-visual').remove()"
            />
          </div>
          <div class="acc-body">
            <div class="acc-title">${esc(p.name)}</div>
            <div class="acc-price">${fmtPrice(p.priceCents)}${p.brand ? ` · ${esc(p.brand)}` : ''}</div>
          </div>
        </a>`).join('');
    };

    let timer;
    input.addEventListener('input', () => { clearTimeout(timer); timer = setTimeout(run, 250); });
    input.closest('form').addEventListener('submit', (e) => {
      e.preventDefault();
      history.replaceState(null, '', `?q=${encodeURIComponent(input.value.trim())}`);
      run();
    });

    const initial = new URLSearchParams(location.search).get('q');
    if (initial) { input.value = initial; run(); }
    input.focus();
  </script>
</Layout>
