---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { PRODUCTS, fmtPrice } from '../../data/products.js';
import { breadcrumbSchema, productSchema } from '../../lib/seo.js';
import { specRows, slugifyCategory, relatedProducts, deviceModel, modelGroups } from '../../lib/shop.js';
import { SITE } from '../../data/site.js';

export function getStaticPaths() {
  return PRODUCTS.map((p) => ({ params: { id: p.id }, props: { p } }));
}
const { p } = Astro.props;
const related = relatedProducts(p, PRODUCTS);
// Link to the model landing page only when Task 3 actually built one (>= 4 products).
const model = deviceModel(p.name);
const hasModelPage =
  model && modelGroups(PRODUCTS.filter((x) => x.category === p.category)).some((g) => g.key === model.key);
// Store-level Google rating only — never emitted as Product aggregateRating.
const googleProfile = (SITE.sameAs || []).find((u) => u.includes('g.page') || u.includes('google'));

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Shop', href: '/shop/' },
];

const schema = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Shop', path: '/shop/' },
    { name: p.name, path: `/shop/${p.id}/` },
  ]),
  productSchema(p),
];
---
<Layout
  title={`${p.name} | Express Repairs`}
  description={`Buy ${p.name} online — ship Australia-wide or free pickup at Express Repairs, Riverwood Plaza.`}
  path={`/shop/${p.id}/`}
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="/shop/cart/" />

  <main id="main-content" class="section-tight">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <a href="/shop/">Shop</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">{p.name}</span>
      </nav>

      <div class="hero-grid" style="margin-top: 32px; align-items: start;">
        <div class="acc-visual" style="border-radius: 20px; border: 1px solid var(--border);">
          <img src={p.image} alt={p.name} width="480" height="480" style="width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: contain; background: #fff; padding: 12px; box-sizing: border-box;" />
        </div>
        <div>
          <h1 style="font-size: clamp(28px, 3.2vw, 38px); font-weight: 800;">{p.name}</h1>
          <p style="font-size: 1.6rem; font-weight: 700; color: var(--brand-700); margin-top: 12px;">{fmtPrice(p.priceCents)}</p>
          <p class="acc-desc" style="margin-top: 6px; color: var(--brand-700); font-weight: 600;">In stock — dispatched in 1-2 business days</p>
          {SITE.rating?.count > 0 && (
            <p style="margin-top: 8px; font-size: 0.95rem;">
              <span style="color: var(--brand-700);" aria-hidden="true">★★★★★</span>{' '}
              {googleProfile
                ? <a href={googleProfile} rel="noopener">{SITE.rating.value} rated by {SITE.rating.count}+ local customers on Google</a>
                : <span>{SITE.rating.value} rated by {SITE.rating.count}+ local customers on Google</span>}
            </p>
          )}
          <div style="display: flex; gap: 10px; align-items: center; margin-top: 16px;">
            <input type="number" min="1" max="20" value="1" data-qty aria-label="Quantity" style="width: 70px; padding: 10px; border: 1px solid var(--border); border-radius: 10px;" />
            <button class="btn btn-primary btn-lg" data-add-to-cart data-id={p.id} data-name={p.name} data-price={p.priceCents}>Add to cart</button>
          </div>
          <p style="margin-top: 16px;"><a href="/shop/cart/">View cart (<span data-cart-count>0</span>)</a></p>
          {hasModelPage && (
            <p style="margin-top: 12px;">
              <a href={`/shop/c/${slugifyCategory(p.category)}/m/${model.key}/`} class="btn btn-ghost btn-sm">
                More {p.category} for {model.label} →
              </a>
            </p>
          )}
          <p class="hero-sub" style="margin-top: 20px;">GST included. Flat $10.95 shipping — free over $99 — or free pickup in store at Riverwood Plaza.</p>
          <dl style="margin-top: 24px; display: grid; grid-template-columns: max-content 1fr; gap: 8px 20px; font-size: 0.95rem;">
            {specRows(p).map(([label, value]) => (
              <>
                <dt style="font-weight: 700;">{label}</dt>
                <dd style="margin: 0; color: var(--muted, #555);">
                  {label === 'Category' ? <a href={`/shop/c/${slugifyCategory(p.category)}/`}>{value}</a> : value}
                </dd>
              </>
            ))}
          </dl>
        </div>
      </div>

      {related.length > 0 && (
        <section style="margin-top: 48px;">
          <h2 class="section-title" style="font-size: clamp(22px, 2.4vw, 28px);">More like this</h2>
          <div class="acc-grid acc-grid--dense" style="margin-top: 24px;">
            {related.map((r) => (
              <a href={`/shop/${r.id}/`} class="acc-card">
                <div class="acc-visual">
                  <img
                    src={r.thumb}
                    alt={r.name}
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="300"
                    style="width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: contain; background: #fff; padding: 12px; box-sizing: border-box;"
                  />
                </div>
                <div class="acc-body">
                  <div class="acc-title">{r.name}</div>
                  <div class="acc-price">{fmtPrice(r.priceCents)}</div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <p style="margin-top: 40px;"><a href="/shop/">← All accessories</a></p>
    </div>
  </main>

  <SiteFooter />
  <script src="../../shop/cart-count.js"></script>
</Layout>
