---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import MobileCta from '../../components/MobileCta.astro';
import { PRODUCTS } from '../../data/products.js';
import { slugifyCategory } from '../../lib/shop.js';
import { breadcrumbSchema } from '../../lib/seo.js';

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Shop', href: '/shop/' },
];

// One tile per category, with its product count — a flat grid of ~3,875
// products is unusable, so /shop/ is a landing page into /shop/c/<category>/.
const categories = [...new Set(PRODUCTS.map((p) => p.category))].map((name) => ({
  name,
  slug: slugifyCategory(name),
  count: PRODUCTS.filter((p) => p.category === name).length,
}));

const schema = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Shop', path: '/shop/' },
]);
---
<Layout
  title="Phone Accessories — Cases, Chargers & More | Express Repairs"
  description="Quality phone accessories with fast shipping Australia-wide or free pickup in store at Riverwood Plaza. Cases, screen protectors, chargers, cables and audio."
  path="/shop/"
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="/shop/cart/" />

  <main id="main-content">
  <section class="hero" style="padding-bottom: 24px;">
    <div class="hero-bg"></div>
    <div class="container-wide" style="position: relative; z-index: 1;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">Shop</span>
      </nav>
      <span class="eyebrow">Accessories</span>
      <h1 class="hero-title" style="font-size: clamp(36px, 4.8vw, 58px); margin-top: 16px; max-width: 720px;">
        Cases, chargers &amp; more, <em>ready today</em>.
      </h1>
      <p class="hero-sub">
        Ship Australia-wide (free over $99) or pick up in store at Riverwood Plaza — same stock as our counter.
      </p>
      <p style="margin-top: 20px;"><a href="/shop/cart/" class="btn btn-ghost btn-sm">View cart (<span data-cart-count>0</span>)</a></p>
    </div>
  </section>

  <section class="section" style="padding-top: 24px;">
    <div class="container-wide">
      {PRODUCTS.length === 0 ? (
        <div class="empty-state" style="text-align: center; padding: 48px 16px;">
          <p class="hero-sub" style="max-width: 480px; margin: 0 auto;">
            Our online range is being loaded. In the meantime, give us a call
            or drop into the shop at Riverwood Plaza — we'll sort you out.
          </p>
          <p style="margin-top: 20px;"><a href="/#contact" class="btn btn-primary btn-sm">Call or visit us</a></p>
        </div>
      ) : (
        <div class="acc-grid">
          {categories.map((cat) => (
            <a href={`/shop/c/${cat.slug}/`} class="acc-card">
              <div class="acc-body">
                <div class="acc-title">{cat.name}</div>
                <div class="acc-price">{cat.count} product{cat.count === 1 ? '' : 's'}</div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  </main>

  <SiteFooter />
  <MobileCta />
  <script src="../../shop/cart-count.js"></script>
</Layout>
