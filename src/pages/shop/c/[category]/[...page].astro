---
import Layout from '../../../../layouts/Layout.astro';
import SiteNav from '../../../../components/SiteNav.astro';
import SiteFooter from '../../../../components/SiteFooter.astro';
import MobileCta from '../../../../components/MobileCta.astro';
import ShopSearch from '../../../../components/ShopSearch.astro';
import ShopFilters from '../../../../components/ShopFilters.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import { PRODUCTS } from '../../../../data/products.js';
import { slugifyCategory, modelGroups } from '../../../../lib/shop.js';
import { breadcrumbSchema, itemListSchema } from '../../../../lib/seo.js';
import { CURATED_TAGS, MIN_TAG_PAGE_PRODUCTS } from '../../../../lib/tags.js';

export function getStaticPaths({ paginate }) {
  const categories = [...new Set(PRODUCTS.map((p) => p.category))];
  return categories.flatMap((category) => {
    const items = PRODUCTS.filter((p) => p.category === category);
    return paginate(items, { pageSize: 48, params: { category: slugifyCategory(category) }, props: { category } });
  });
}

const { page, category } = Astro.props;
const { category: categorySlug } = Astro.params;

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Shop', href: '/shop/' },
];

const schema = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Shop', path: '/shop/' },
    { name: category, path: `/shop/c/${categorySlug}/` },
  ]),
  itemListSchema(page),
];

// True whole-category brand counts (the old chips counted only this page's 48).
const inCat = PRODUCTS.filter((p) => p.category === category);
const brandCounts = [...new Set(inCat.map((p) => p.brand).filter(Boolean))]
  .sort()
  .map((name) => ({ name, count: inCat.filter((p) => p.brand === name).length }));
const models = modelGroups(inCat);
// Curated-tag chips: only tags with a real presence in this category.
const tagChips = CURATED_TAGS.map((t) => ({
  ...t,
  count: inCat.filter((p) => p.tags.includes(t.tag)).length,
})).filter((t) => t.count >= MIN_TAG_PAGE_PRODUCTS);
---
<Layout
  title={`${category} | Express Repairs Shop`}
  description={`Shop ${category} — ship Australia-wide (free over $99) or free pickup at Express Repairs, Riverwood Plaza.`}
  path={page.url.current}
  schema={schema}
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="/shop/cart/" />

  <main id="main-content" class="section-tight">
    <div class="container-wide">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <a href="/shop/">Shop</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">{category}</span>
      </nav>

      <h1 class="section-title" style="margin-top: 16px; font-size: clamp(28px, 3.2vw, 38px);">{category}</h1>
      <p class="hero-sub">{page.total} products — ship Australia-wide (free over $99) or free pickup in store.</p>

      <ShopSearch placeholder="Search accessories" />

      <ShopFilters category={category} categorySlug={categorySlug} brands={brandCounts} models={models} tags={tagChips} />

      <div class="acc-grid acc-grid--dense" data-category={category} style="margin-top: 24px;">
        {page.data.map((p) => <ProductCard p={p} />)}
      </div>

      <div id="pagination" style="display: flex; align-items: center; justify-content: center; gap: 24px; margin-top: 40px;">
        {page.url.prev ? <a href={page.url.prev} class="btn btn-ghost btn-sm">← Previous</a> : <span />}
        <span class="hero-sub" style="margin: 0;">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next ? <a href={page.url.next} class="btn btn-ghost btn-sm">Next →</a> : <span />}
      </div>

      <p style="margin-top: 40px;"><a href="/shop/">← All categories</a></p>
    </div>
  </main>

  <SiteFooter />
  <MobileCta />
  <script src="../../../../shop/cart-count.js"></script>
</Layout>
