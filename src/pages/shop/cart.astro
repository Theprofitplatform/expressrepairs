---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ShopCartPage from '../../components/ShopCartPage.jsx';
import { breadcrumbSchema } from '../../lib/seo.js';

const navLinks = [
  { label: 'Repairs', href: '/repairs/' },
  { label: 'Shop', href: '/shop/' },
];

const schema = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Shop', path: '/shop/' },
  { name: 'Cart', path: '/shop/cart/' },
]);
---
<Layout
  title="Your Cart | Express Repairs"
  description="Review your accessories cart and check out — ship Australia-wide or free pickup at Riverwood Plaza."
  path="/shop/cart/"
  schema={schema}
  noindex
  htmlAttrs={{ 'data-palette': 'electric-blue', 'data-fontpair': 'jakarta', 'data-dark': 'false' }}
>
  <SiteNav links={navLinks} ctaHref="/shop/cart/" />

  <main id="main-content" class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <a href="/shop/">Shop</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">Cart</span>
      </nav>

      <h1 style="font-size: clamp(28px, 3.2vw, 38px); font-weight: 800; margin-top: 24px;">Your cart</h1>

      <div style="margin-top: 24px; max-width: 640px;">
        <ShopCartPage client:load />
      </div>
    </div>
  </main>

  <SiteFooter />
</Layout>
