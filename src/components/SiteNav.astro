---
import { SITE } from '../data/site.js';
// Static inner-page nav. Pass `links` ([{label, href}]) and optional `ctaHref`.
const { links = [], ctaHref = '#cta' } = Astro.props;
---
<header class="nav">
  <div class="container-wide nav-inner">
    <a href="/" class="brand">
      <span class="brand-mark">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="7" y="2" width="10" height="20" rx="2"></rect><line x1="11" y1="18" x2="13" y2="18"></line></svg>
      </span>
      {SITE.name}
    </a>
    <nav class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="nav-cta">
      <a href={SITE.phoneHref} class="nav-phone">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        <span>{SITE.phone}</span>
      </a>
      <a href={ctaHref} class="btn btn-primary btn-sm">{ctaHref === '/shop/cart/' ? <>Cart (<span data-cart-count>0</span>)</> : 'Get a quote'}</a>
    </div>
  </div>
</header>
