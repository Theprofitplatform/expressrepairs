---
// Shared product card for shop grids. Mirrored in the client card() renderer
// in ShopFilters.astro — keep both in sync.
import { fmtPrice } from '../data/products.js';
const { p } = Astro.props;
---
<div class="acc-card" data-brand={p.brand}>
  <a href={`/shop/${p.id}/`} class="acc-card-link">
    <div class="acc-visual">
      <img
        src={p.thumb}
        alt={p.name}
        loading="lazy"
        decoding="async"
        width="400"
        height="300"
        style="width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: contain; background: #fff; padding: 12px; box-sizing: border-box;"
      />
    </div>
    <div class="acc-body">
      {p.brand && <div class="acc-brand">{p.brand}</div>}
      <div class="acc-title">{p.name}</div>
    </div>
  </a>
  <div class="acc-buy">
    <span class="acc-price">{fmtPrice(p.priceCents)}</span>
    <button class="btn btn-primary btn-sm" data-add-to-cart data-id={p.id} data-price={p.priceCents}>Add to cart</button>
  </div>
</div>
