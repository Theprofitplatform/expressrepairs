---
// Sticky filter toolbar for category/model/tag pages. Server renders the
// controls plus one collapsed "Browse by model or type" block holding the
// static SEO links (tag chips + model-family accordions) with TRUE
// whole-scope counts. The script filters over search-index.json via
// filterProducts — never just the 48 server-rendered cards.
import { modelFamilies } from '../lib/shop.js';
const { category, categorySlug, model = '', tag = '', brands = [], models = [], tags = [] } = Astro.props;
const families = modelFamilies(models);
---
<div id="shop-filters" data-category={category} data-category-slug={categorySlug} data-model={model} data-tag={tag}>
  <div class="filter-bar">
    <details class="filter-drawer">
      <summary>Filter &amp; sort</summary>
      <div class="filter-toolbar">
        <input
          id="model-filter"
          type="search"
          list="model-options"
          placeholder="Filter by your model — e.g. iPhone 15 Pro, S24 Ultra"
          aria-label="Filter this list by device model or keyword"
          autocomplete="off"
        />
        <datalist id="model-options">
          {models.map((m) => <option value={m.label} data-key={m.key} />)}
        </datalist>
        {brands.length > 1 && (
          <label class="filter-label">
            Brand
            <select id="brand-select" aria-label="Filter by brand">
              <option value="">All brands</option>
              {brands.map((b) => (
                <option value={b.name}>{b.name} ({b.count})</option>
              ))}
            </select>
          </label>
        )}
        <label class="filter-label">
          Price
          <select id="price-select" aria-label="Filter by price">
            <option value="">Any price</option>
            <option value="under-20">Under $20</option>
            <option value="20-50">$20–$50</option>
            <option value="over-50">Over $50</option>
          </select>
        </label>
        <label class="filter-label">
          Sort
          <select id="sort-select">
            <option value="">Featured</option>
            <option value="price-asc">Price: low to high</option>
            <option value="price-desc">Price: high to low</option>
          </select>
        </label>
      </div>
    </details>
    <div id="active-filters" class="chip-row" aria-label="Active filters" hidden></div>
  </div>

  {(tags.length > 0 || families.length > 0) && (
    <details class="model-group browse-links">
      <summary>Browse by model or type</summary>
      <div class="browse-links-body">
        {tags.length > 0 && (
          <nav aria-label="Shop by type" class="chip-row">
            {tags.map((t) => (
              <a href={`/shop/t/${t.tag}/`} class="btn btn-ghost btn-sm">
                {t.label} <span style="opacity:.6">({t.count})</span>
              </a>
            ))}
          </nav>
        )}
        {families.length > 0 && (
          <nav aria-label="Shop by model" class="model-nav">
            {families.map(({ family, models: fam }) => (
              <details class="model-group">
                <summary>{family} <span class="model-count">({fam.length} model{fam.length === 1 ? '' : 's'})</span></summary>
                <div class="chip-row">
                  {fam.map((m) => (
                    <a href={`/shop/c/${categorySlug}/m/${m.key}/`} class="btn btn-ghost btn-sm">
                      {m.label} <span style="opacity:.6">({m.count})</span>
                    </a>
                  ))}
                </div>
              </details>
            ))}
          </nav>
        )}
      </div>
    </details>
  )}

  <p id="filter-status" class="hero-sub" role="status" style="margin-top: 12px;" hidden></p>
</div>

<script>
  import { filterProducts } from '../shop/filter-core.js';
  import { thumbSrc } from '../shop/search-core.js';

  const root = document.getElementById('shop-filters');
  const grid = document.querySelector('.acc-grid');
  const pagination = document.getElementById('pagination');
  const status = document.getElementById('filter-status');
  const input = document.getElementById('model-filter');
  const sortSel = document.getElementById('sort-select');
  const brandSel = document.getElementById('brand-select');
  const priceSel = document.getElementById('price-select');
  const chipsRow = document.getElementById('active-filters');
  const { category, categorySlug, model, tag } = root.dataset;

  const fmtPrice = (c) => (c % 100 === 0 ? `$${c / 100}` : `$${(c / 100).toFixed(2)}`);
  const esc = (s) => s.replace(/[&<>"']/g, (ch) => `&#${ch.charCodeAt(0)};`);
  // ponytail: render cap keeps a filter-only view of a 2,400-product category
  // from creating thousands of DOM nodes; raise if anyone ever pages past it.
  const CAP = 500;

  const state = { brand: '', price: '', sort: '', q: '' };
  const controls = { q: input, brand: brandSel, price: priceSel, sort: sortSel };
  let orig = null;
  let indexP = null;

  // Keep in sync with ProductCard.astro.
  const card = (p) => `
    <div class="acc-card" data-brand="${esc(p.brand)}">
      <a href="/shop/${esc(p.id)}/" class="acc-card-link">
        <div class="acc-visual">
          <img src="${esc(thumbSrc(p.id))}" alt="${esc(p.name)}"
            loading="lazy" decoding="async" width="400" height="300"
            style="width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: contain; background: #fff; padding: 12px; box-sizing: border-box;" />
        </div>
        <div class="acc-body">
          ${p.brand ? `<div class="acc-brand">${esc(p.brand)}</div>` : ''}
          <div class="acc-title">${esc(p.name)}</div>
        </div>
      </a>
      <div class="acc-buy">
        <span class="acc-price">${fmtPrice(p.priceCents)}</span>
        <button class="btn btn-primary btn-sm" data-add-to-cart data-id="${esc(p.id)}" data-price="${p.priceCents}">Add to cart</button>
      </div>
    </div>`;

  const syncUrl = () => {
    const params = new URLSearchParams(location.search);
    for (const [k, v] of Object.entries(state)) v ? params.set(k, v) : params.delete(k);
    const qs = params.toString();
    history.replaceState(null, '', location.pathname + (qs ? `?${qs}` : ''));
  };

  // Human label per active facet — select facets reuse their own option text.
  const chipLabel = (k, v) =>
    k === 'q' ? `“${v}”` : controls[k]?.querySelector(`option[value="${CSS.escape(v)}"]`)?.textContent.trim() ?? v;

  const renderChips = () => {
    const active = Object.entries(state).filter(([, v]) => v);
    chipsRow.hidden = active.length === 0;
    chipsRow.innerHTML = active.length
      ? active
          .map(([k, v]) => {
            const label = esc(chipLabel(k, v));
            return `<button class="btn btn-ghost btn-sm" data-clear="${k}" aria-label="Remove filter: ${label}">${label} ✕</button>`;
          })
          .join('') + '<button class="btn btn-ghost btn-sm" data-clear="*">Clear all</button>'
      : '';
  };

  const apply = async () => {
    syncUrl();
    renderChips();
    if (!state.brand && !state.price && !state.sort && !state.q) {
      if (orig !== null) { grid.innerHTML = orig; pagination.style.display = ''; status.hidden = true; }
      return;
    }
    orig ??= grid.innerHTML;
    indexP ??= fetch('/shop/search-index.json').then((r) => r.json());
    const hits = filterProducts(await indexP, { category, model, tag, ...state });
    status.hidden = false;
    status.textContent = hits.length
      ? `${hits.length} product${hits.length === 1 ? '' : 's'}${hits.length > CAP ? ` — showing first ${CAP}` : ''}`
      : 'No products match those filters — clear one and try again.';
    grid.innerHTML = hits.slice(0, CAP).map(card).join('');
    pagination.style.display = 'none';
  };

  chipsRow.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-clear]');
    if (!btn) return;
    for (const k of btn.dataset.clear === '*' ? Object.keys(state) : [btn.dataset.clear]) {
      state[k] = '';
      if (controls[k]) controls[k].value = '';
    }
    apply();
  });

  sortSel?.addEventListener('change', () => { state.sort = sortSel.value; apply(); });
  brandSel?.addEventListener('change', () => { state.brand = brandSel.value; apply(); });
  priceSel?.addEventListener('change', () => { state.price = priceSel.value; apply(); });
  let timer;
  input?.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(() => { state.q = input.value.trim(); apply(); }, 200);
  });

  // Exact (case-insensitive) datalist match → navigate to that model's SEO page.
  const modelOpts = [...document.querySelectorAll('#model-options option')];
  const goToModel = () => {
    if (!categorySlug || !modelOpts.length) return;
    const v = input.value.trim().toLowerCase();
    const hit = modelOpts.find((o) => o.value.toLowerCase() === v);
    if (hit && hit.dataset.key !== model) location.href = `/shop/c/${categorySlug}/m/${hit.dataset.key}/`;
  };
  input?.addEventListener('change', goToModel);
  input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') goToModel(); });

  // Restore shareable/back-button state from the URL.
  const params = new URLSearchParams(location.search);
  let dirty = false;
  for (const k of Object.keys(state)) {
    const v = params.get(k);
    if (!v) continue;
    state[k] = v;
    dirty = true;
    if (controls[k]) controls[k].value = v;
  }
  if (dirty) apply();
</script>
