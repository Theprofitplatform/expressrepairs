---
// Shop search box with a live product-suggestion dropdown (top 6 matches with
// photo + price, then a "see all" row). Falls back to a plain form submit to
// /shop/search/ when JS hasn't loaded.
const { placeholder = 'Search accessories — e.g. iPhone 15 case' } = Astro.props;
---
<form action="/shop/search/" class="shop-search" style="margin-top: 20px; max-width: 520px; display: flex; gap: 8px;">
  <div style="position: relative; flex: 1;">
    <input
      type="search"
      name="q"
      placeholder={placeholder}
      aria-label="Search accessories"
      autocomplete="off"
      role="combobox"
      aria-expanded="false"
      aria-autocomplete="list"
      style="width: 100%; box-sizing: border-box; padding: 12px 16px; font-size: 16px; border: 1px solid var(--border, #d0d5dd); border-radius: 10px;"
    />
    <div class="shop-suggest" role="listbox" aria-label="Product suggestions" hidden></div>
  </div>
  <button type="submit" class="btn btn-primary btn-sm">Search</button>
</form>

<!-- is:global — the rows are injected with innerHTML at runtime, so Astro's
     scoped-style attribute never lands on them. .shop-suggest namespaces it. -->
<style is:global>
  .shop-suggest {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid var(--border, #d0d5dd);
    border-radius: 10px;
    box-shadow: 0 12px 32px rgba(16, 24, 40, 0.14);
    max-height: 60vh;
    overflow-y: auto;
    z-index: 50;
  }
  .shop-suggest a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    text-decoration: none;
    color: inherit;
  }
  .shop-suggest a.active,
  .shop-suggest a:hover {
    background: var(--surface, #f2f4f7);
  }
  .shop-suggest img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    background: #fff;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .shop-suggest .s-name {
    flex: 1;
    font-size: 14px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .shop-suggest .s-price {
    font-weight: 700;
    font-size: 14px;
    white-space: nowrap;
  }
  .shop-suggest .s-all {
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    color: var(--brand-700, #1d4ed8);
    border-top: 1px solid var(--border, #e4e7ec);
  }
</style>

<script>
  import { searchProducts, thumbSrc } from '../shop/search-core.js';

  const fmtPrice = (c) => (c % 100 === 0 ? `$${c / 100}` : `$${(c / 100).toFixed(2)}`);
  const esc = (s) => s.replace(/[&<>"']/g, (ch) => `&#${ch.charCodeAt(0)};`);
  let indexPromise = null;
  const loadIndex = () => (indexPromise ??= fetch('/shop/search-index.json').then((r) => r.json()));

  for (const form of document.querySelectorAll('.shop-search')) {
    const input = form.querySelector('input');
    const box = form.querySelector('.shop-suggest');
    let active = -1;

    // .hero uses overflow:hidden for its background art, which clips the
    // dropdown — lift it only while suggestions are open.
    const hero = form.closest('.hero');
    const close = () => {
      box.hidden = true;
      active = -1;
      input.setAttribute('aria-expanded', 'false');
      if (hero) hero.style.overflow = '';
    };

    const render = ({ hits, total }, q) => {
      if (!hits.length) { close(); return; }
      box.innerHTML =
        hits.slice(0, 6).map((p) => `
          <a href="/shop/${esc(p.id)}/" role="option">
            <img src="${esc(thumbSrc(p.id))}" alt="" loading="lazy" width="44" height="44" />
            <span class="s-name">${esc(p.name)}</span>
            <span class="s-price">${fmtPrice(p.priceCents)}</span>
          </a>`).join('') +
        `<a class="s-all" href="/shop/search/?q=${encodeURIComponent(q)}" role="option">All ${total} result${total === 1 ? '' : 's'} →</a>`;
      box.hidden = false;
      active = -1;
      input.setAttribute('aria-expanded', 'true');
      if (hero) hero.style.overflow = 'visible';
    };

    let timer;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      const q = input.value.trim();
      if (q.length < 2) { close(); return; }
      timer = setTimeout(async () => render(searchProducts(await loadIndex(), q, 6), q), 150);
    });

    input.addEventListener('keydown', (e) => {
      const opts = box.hidden ? [] : [...box.querySelectorAll('a')];
      if (!opts.length) return;
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        active = (active + (e.key === 'ArrowDown' ? 1 : -1) + opts.length) % opts.length;
        opts.forEach((o, i) => o.classList.toggle('active', i === active));
      } else if (e.key === 'Enter' && active >= 0) {
        e.preventDefault();
        location.href = opts[active].href;
      } else if (e.key === 'Escape') {
        close();
      }
    });

    // blur fires before the suggestion link's click — use pointerdown ordering
    document.addEventListener('pointerdown', (e) => { if (!form.contains(e.target)) close(); });
  }
</script>
