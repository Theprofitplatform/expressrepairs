---
import { SITE } from '../data/site.js';
// Props: title, sub, secondaryLabel, secondaryHref.
const {
  title,
  sub = "Call now or get a free quote — we'll confirm your price before you come in.",
  secondaryLabel = 'See pricing',
  secondaryHref = '/repairs/',
} = Astro.props;
---
<section class="section-tight" id="cta" style="padding-bottom: 96px;">
  <div class="container-wide">
    <div class="cta-band">
      <div class="cta-band-bg"></div>
      <div class="cta-band-inner">
        <div>
          <h2 class="cta-band-title">{title}</h2>
          <p class="cta-band-sub">{sub}</p>
        </div>
        <div class="cta-band-actions">
          <a href={SITE.phoneHref} class="btn btn-on-dark btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            {SITE.phone}
          </a>
          <a href={secondaryHref} class="btn btn-outline-dark btn-lg">{secondaryLabel}</a>
        </div>
      </div>
    </div>
  </div>
</section>
