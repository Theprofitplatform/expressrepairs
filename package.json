{
  "name": "expressrepairs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Astro site for expressrepairs.com.au on Cloudflare Pages",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "optimize:images": "node scripts/optimize-images.mjs",
    "sync:products": "node scripts/sync-products.mjs",
    "whoami": "wrangler whoami",
    "deployments": "wrangler pages deployment list --project-name expressrepairs",
    "deploy": "astro build && wrangler pages deploy dist --project-name expressrepairs --branch main"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "wrangler": "^4"
  }
}
